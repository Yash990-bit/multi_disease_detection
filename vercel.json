{
    "version": 2,
    "builds": [
        {
            "src": "frontend/package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "dist"
            }
        },
        {
            "src": "backend/api.py",
            "use": "@vercel/python"
        }
    ],
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "backend/api.py"
        },
        {
            "source": "/((?!api/).*)",
            "destination": "/frontend/$1"
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "backend/api.py"
        },
        {
            "handle": "filesystem"
        },
        {
            "src": "/(.*)",
            "status": 200,
            "dest": "/index.html"
        }
    ]
}